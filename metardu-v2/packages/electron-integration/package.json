{
  "name": "@metardu/electron-integration",
  "version": "0.1.0",
  "description": "Electron integration layer for MetaRDU v2.0 — spawns the Rust sidecar, provides typed IPC wrappers, and bridges to the renderer via contextBridge",
  "license": "MIT",
  "author": "error302",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
