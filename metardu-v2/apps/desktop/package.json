{
  "name": "@metardu/desktop",
  "version": "0.2.0",
  "description": "MetaRDU Desktop — Electron shell that hosts the React UI, spawns the Rust sidecar, and brokers IPC between renderer and sidecar.",
  "license": "MIT",
  "author": "error302",
  "type": "module",
  "main": "./dist/main/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && electron .",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@metardu/electron-integration": "*",
    "@metardu/ipc-schemas": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
