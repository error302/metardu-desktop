{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "noImplicitAny": false,
    "strict": false,
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/**/*"],
  "exclude": [
    "src/compute/**",
    "src/cadastral/**",
    "src/audit/**",
    "src/auth/**",
    "src/offline/**",
    "src/security/**",
    "src/workers/**",
    "src/ai/**",
    "src/api/**",
    "src/api-client/**",
    "src/cache/**",
    "src/data/**",
    "src/db/**",
    "src/drawing/**",
    "src/email-templates/**",
    "src/enterprise/**",
    "src/validation/**",
    "src/site.ts",
    "src/db.ts",
    "src/auth.ts",
    "src/auth-v5.ts",
    "src/community.ts",
    "src/cors.ts",
    "src/env.ts",
    "src/cpd.ts",
    "src/apiHandler.ts",
    "src/email.ts",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/engine/solution/**"
  ]
}
