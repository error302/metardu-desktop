{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../dist-electron",
    "rootDir": ".",
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "noEmit": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0"
  },
  "include": ["./**/*.ts"]
}
