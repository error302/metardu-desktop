{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../dist-electron",
    "composite": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "noEmit": false,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strict": false,
    "ignoreDeprecations": "5.0",
    "paths": {
      "@metardu/engine": ["../../../packages/engine/src/index.ts"],
      "@metardu/engine/*": ["../../../packages/engine/src/*"]
    }
  },
  "include": ["./**/*.ts"]
}
